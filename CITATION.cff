title: "reach: Time-Free Quantum Reachability Analysis"
version: 0.1.0
date-released: 2025-01-03
url: "https://github.com/TomaszAnd/reach"
repository-code: "https://github.com/TomaszAnd/reach"
type: software
license: MIT
